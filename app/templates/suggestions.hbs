<main>
	<section class="data">
		<div>
			<table>
				<thead>
					<tr>
						<th>Tag</th>
						<th>Description</th>
						<th></th>
					</tr>
				</thead>
				<tbody>
					{{#each model as |suggestion|}}
						<tr>
							<td>{{suggestion.tag}}</td>
							<td>{{suggestion.description}}</td>
							<td class="controls">
								<ul>
									{{link-to '' 'tags.new' (query-params tag=suggestion.tag) class="add" tagName="li" data-tooltip="Add" data-tooltip-direction="left"}}
									{{with-tooltip "Remove" "left" true class="remove" tagName="li" action=(action 'remove' suggestion)}}
								</ul>
							</td>
						</tr>
					{{/each}}
				</tbody>
			</table>
			{{infinity-loader infinityModel=model scrollable=".data"}}
		</div>
	</section>
</main>
